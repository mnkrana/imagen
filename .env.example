# --- API Keys (at least one required) ---
OPENAI_API_KEY=sk-...
STABILITY_API_KEY=...

# --- Google Cloud Storage ---
GCS_BUCKET=my-image-bucket
GCS_OBJECT_PREFIX=images/

# --- Provider Settings ---
IMAGEN_PROVIDER=openai           # "openai" or "stability"
IMAGEN_MODEL=gpt-image-2
IMAGEN_SIZE=1024x1024
IMAGEN_QUALITY=standard
IMAGEN_OUTPUT_FORMAT=webp        # output format (used by Stability)

# --- Stability AI (when IMAGEN_PROVIDER=stability) ---
STABILITY_ENDPOINT=https://api.stability.ai/v1
STABILITY_MODEL=stable-diffusion-xl-1024-v1-0
STABILITY_CFG_SCALE=7.0
STABILITY_STEPS=30
STABILITY_STYLE_PRESET=photographic  # optional: "photographic", "digital-art", "anime", etc.

# --- HTTP / Retry ---
IMAGEN_HTTP_TIMEOUT=90s
IMAGEN_MAX_RETRIES=5
