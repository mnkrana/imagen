# --- API Keys (at least one required) ---
OPENAI_API_KEY=sk-...
STABILITY_API_KEY=...

# --- Google Cloud Storage ---
GCS_BUCKET=my-image-bucket
GCS_OBJECT_PREFIX=images/

# --- Provider Settings ---
IMAGEN_PROVIDER=openai           # "openai" or "stability"
IMAGEN_MODEL=gpt-image-2
IMAGEN_SIZE=1024x1024
IMAGEN_QUALITY=standard

# --- HTTP / Retry ---
IMAGEN_HTTP_TIMEOUT=90s
IMAGEN_MAX_RETRIES=5
